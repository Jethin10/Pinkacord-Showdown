# ─── Required ─────────────────────────────────────────────────────────────────
# Shared password for the admin panel. Must be >= 8 characters.
PINKACORD_ADMIN_PASSWORD=

# ─── Network ──────────────────────────────────────────────────────────────────
# PS server listens here. Default 8000.
PINKACORD_PS_HOST=127.0.0.1
PINKACORD_PS_PORT=8000

# Admin panel listens here. Default 8001, localhost-only.
# Set bind to 0.0.0.0 only if you are behind a firewall/VPN and intentionally exposing it.
PINKACORD_ADMIN_BIND=127.0.0.1
PINKACORD_ADMIN_PORT=8001

# ─── Optional: bot-account for one-click hotpatch ────────────────────────────
# A registered PS account that is also listed in config/usergroups.csv with
# Administrator (~) rank. When set, the panel can apply changes to the live PS
# server itself instead of asking the operator to paste /hotpatch commands.
# Leave blank to disable auto-apply.
PINKACORD_BOT_USERNAME=
PINKACORD_BOT_PASSWORD=

# Login server used to authenticate the bot. Defaults to PS Main. Change only if
# you operate your own login server.
# PINKACORD_LOGIN_URL=https://play.pokemonshowdown.com/api/login

# How long the panel will wait for the hotpatch round-trip before giving up.
# PINKACORD_HOTPATCH_TIMEOUT_MS=15000

# ─── Optional: Discord bridge bot (tools/discord-bot/bot.js) ─────────────────
# Set to enable tournament announcements in a Discord channel.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# PINKACORD_BOT_WATCH_ROOMS=lobby,tournaments

# ─── Optional: AI ability translator (free) ─────────────────────────────────
# When set, the ability editor can translate ANY plain-English description
# (including novel abilities not in our preset registry) into working code.
# Default backend is Groq — free, no credit card, fast Llama 3.3 70B.
#
# Quick setup (free):
#   1. Sign up at https://console.groq.com/  (no card required)
#   2. Create an API key at https://console.groq.com/keys
#   3. Paste it below and restart the launcher
# LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
#
# Alternative backends (any OpenAI-compatible endpoint works):
#   Ollama (local, fully offline — no key needed):
#     LLM_API_URL=http://localhost:11434/v1
#     LLM_MODEL=llama3.1
#   OpenRouter (free model tier):
#     LLM_API_URL=https://openrouter.ai/api/v1
#     LLM_API_KEY=sk-or-...
#     LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
#
# Defaults (only override if you know you need to):
# LLM_API_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
